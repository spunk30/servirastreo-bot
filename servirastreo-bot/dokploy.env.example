# ===========================================================================
# Variables que debes pegar en la pestaña ENVIRONMENT de Dokploy
# (Servirastreo Bit -> production -> Servirastreo Bot -> pestana Environment)
# ===========================================================================
#
# Genera cada clave larga con este comando en tu PC o en el VPS:
#   openssl rand -hex 24
# ===========================================================================

# Clave de la base de datos Postgres (usala identica abajo en DATABASE_URI)
POSTGRES_PASSWORD=CAMBIAME_con_openssl_rand_hex_24

# Clave global para hablarle a Evolution API
EVOLUTION_API_KEY=CAMBIAME_con_openssl_rand_hex_24

# URL publica que apuntara a Evolution API (la configuras en la pestana Domains)
# Si todavia no tienes dominio, dejala asi temporalmente y la editas despues.
EVOLUTION_SERVER_URL=https://evolution.tu-dominio.com

# Tu llave de OpenAI (platform.openai.com -> API keys)
OPENAI_API_KEY=sk-proj-CAMBIAME_pon_aqui_tu_llave_real

# Credenciales para entrar al panel web del bot
PANEL_USER=deivis
PANEL_PASSWORD=CAMBIAME_clave_para_el_panel

# Token que autentica el webhook entre Evolution y el bot
WEBHOOK_TOKEN=CAMBIAME_con_openssl_rand_hex_24
